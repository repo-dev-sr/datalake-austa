# Spark Thrift / Kyuubi (LDAP) — carregue antes do dbt:  set -a && source .env && set +a
SPARK_THRIFT_HOST=thrift.seu-host.internal
SPARK_THRIFT_PORT=10009
SPARK_THRIFT_USER=seu_usuario
SPARK_THRIFT_PASSWORD=

# Opcional: diretório onde está profiles.yml (pasta dbt do projeto)
